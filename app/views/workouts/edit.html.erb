<div class="max-w-3xl mx-auto mt-10">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Edit Workout Session</h1>
    <%= link_to "Cancel", root_path, class: "text-gray-500 hover:text-gray-800" %>
  </div>

  <!--  -->
  <%= form_with(model: @workout, html: { multipart: true }, class: "bg-white p-6 rounded-lg shadow-md border border-gray-200", data: { controller: "nested-form" }) do |form| %>
    
    <!-- Copy the exact contents of your app/views/workouts/new.html.erb form here -->
    <!-- (Include the date input, notes text area, media field, and exercise fields) -->

    <div class="mt-8 flex justify-end">
      <%= form.submit "Update Full Workout", class: "bg-blue-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-blue-700 shadow cursor-pointer" %>
    </div>
  <% end %>
</div>