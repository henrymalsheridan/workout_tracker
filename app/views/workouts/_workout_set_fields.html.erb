<!--  -->
<div class="nested-fields flex items-center gap-4 bg-white p-3 rounded border border-gray-200 shadow-sm mb-2" data-controller="toggle">
  
  <%= f.hidden_field :_destroy %>

  <!-- toggle checkbox -->
  <div class="flex items-center gap-2 border-r border-gray-200 pr-4">
    <input type="checkbox" data-action="change->toggle#switch" class="rounded border-gray-300 text-blue-600">
    <label class="text-sm font-bold text-gray-500">Time?</label>
  </div>

  <!-- Reps/Weight code in a target div -->
  <div data-toggle-target="strengthFields" class="flex items-center gap-4">
    <div class="flex items-center gap-2">
      <%= f.label :reps, "Reps", class: "text-sm text-gray-600" %>
      <%= f.number_field :reps, class: "w-20 border-gray-300 rounded p-1 border", min: 0 %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.label :weight, "Weight (lbs)", class: "text-sm text-gray-600" %>
      <%= f.number_field :weight, step: "0.5", class: "w-24 border-gray-300 rounded p-1 border", min: 0 %>
    </div>
  </div>

  <!-- new Duration field ina hidden target div -->
  <div data-toggle-target="cardioFields" class="hidden flex items-center gap-2">
    <%= f.label :duration, "Duration (mins)", class: "text-sm text-gray-600" %>
    <%= f.number_field :duration, class: "w-24 border-gray-300 rounded p-1 border", min: 0 %>
  </div>

  
  <button data-action="click->nested-form#remove" type="button" class="text-red-500 hover:text-red-700 text-sm font-bold ml-auto">Remove</button>
</div>