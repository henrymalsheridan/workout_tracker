<div class="max-w-3xl mx-auto mt-10 mb-20">
  <h1 class="text-3xl font-bold mb-6">Log a New Workout</h1>

  <%= form_with(model: @workout, class: "bg-white p-6 rounded-lg shadow-md border border-gray-200") do |form| %>
    
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <%= form.label :workout_type_id, "Workout Type", class: "block font-bold mb-2 text-gray-700" %>
        <%= form.collection_select :workout_type_id, WorkoutType.all, :id, :name, { prompt: "Select a type..." }, { class: "w-full border-gray-300 rounded-md p-2 border bg-gray-50" } %>
      </div>

      <div>
        <%= form.label :date, "Date", class: "block font-bold mb-2 text-gray-700" %>
        <%= form.date_field :date, class: "w-full border-gray-300 rounded-md p-2 border bg-gray-50" %>
      </div>
    </div>

    <div class="mb-8">
      <%= form.label :notes, "Session Notes", class: "block font-bold mb-2 text-gray-700" %>
      <%= form.text_area :notes, rows: 2, class: "w-full border-gray-300 rounded-md p-2 border bg-gray-50" %>
    </div>

    <div class="mb-8 mt-4">
      <%= form.label :media, "Attach Photos or Videos", class: "block font-bold mb-2 text-gray-700" %>
      <%= form.file_field :media, multiple: true, class: "w-full text-gray-700 p-2 border border-gray-300 rounded-md bg-gray-50" %>
    </div>

    <hr class="my-6 border-gray-300">
    
    <!-- The Outer Controller For Exercises -->
    <div data-controller="nested-form">
      <h2 class="text-2xl font-bold mb-4 text-blue-800">Exercises</h2>

      <!-- Target area where existing and new exercises will load -->
      <div data-controller="nested-form" data-placeholder="NEW_RECORD">
        <%= form.fields_for :exercise_logs do |log_form| %>
          <%= render "exercise_log_fields", f: log_form %>
        <% end %>
      </div>

      <!--  Button for Exercises -->
      <button data-action="click->nested-form#add" type="button" class="mb-8 text-blue-600 font-bold hover:underline text-lg">
        + Add Another Exercise
      </button>

      <!-- Hidden template that creates a brand new blue box when clicked -->
      <template data-nested-form-target="template">
        <%= form.fields_for :exercise_logs, ExerciseLog.new, child_index: 'NEW_RECORD' do |log_form| %>
          <%= render "exercise_log_fields", f: log_form %>
        <% end %>
      </template>
    </div>

    <div class="mt-8 flex justify-between items-center">
      <%= link_to "Cancel", root_path, class: "text-gray-500 hover:text-gray-800 font-semibold" %>
      <%= form.submit "Save Full Workout", class: "bg-blue-600 text-white font-bold py-3 px-6 rounded-lg hover:bg-blue-700 cursor-pointer shadow-md transition" %>
    </div>

  <% end %>
</div>