<div class="nested-fields bg-blue-50 p-4 rounded-lg border border-blue-200 mb-6">
  
  <div class="mb-4">
    <%= f.label :exercise_id, "Select Exercise", class: "block font-bold mb-2 text-gray-700" %>
    <%= f.collection_select :exercise_id, Exercise.all, :id, :name, { prompt: "Select an exercise..." }, { class: "w-full border-gray-300 rounded-md p-2 border bg-white" } %>
  </div>

  <!-- Controller (For Sets) -->
  <div data-controller="nested-form">
    <h3 class="font-bold text-gray-700 mb-2">Sets:</h3>
    
    <div data-nested-form-target="target">
      <%= f.fields_for :workout_sets do |set_form| %>
        <%= render "workout_set_fields", f: set_form %>
      <% end %>
    </div>

    <button data-action="click->nested-form#add" type="button" class="mt-2 text-sm text-blue-600 font-bold hover:underline">+ Add Another Set</button>

    <template data-nested-form-target="template">
      <%= f.fields_for :workout_sets, WorkoutSet.new, child_index: 'NEW_RECORD' do |set_form| %>
        <%= render "workout_set_fields", f: set_form %>
      <% end %>
    </template>
  </div>

</div>