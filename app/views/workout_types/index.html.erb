<div class="max-w-2xl mx-auto mt-10">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Workout Types</h1>
    <%= link_to "+ Add New Type", new_workout_type_path, class: "bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-gray-200 overflow-hidden">
    <ul class="divide-y divide-gray-200">
      <% @workout_types.each do |type| %>
        <li class="p-4 hover:bg-gray-50 flex justify-between items-center">
          <span class="font-semibold text-gray-800"><%= type.name %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>