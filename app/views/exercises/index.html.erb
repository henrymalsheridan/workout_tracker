<div class="max-w-2xl mx-auto mt-10">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Exercise Library</h1>
    <%= link_to "+ Add New Exercise", new_exercise_path, class: "bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700" %>
  </div>

  <div class="bg-white rounded-lg shadow-md border border-gray-200 overflow-hidden">
    <ul class="divide-y divide-gray-200">
      <% @exercises.each do |exercise| %>
        <li class="p-4 hover:bg-gray-50 flex justify-between items-center">
          <span class="font-semibold text-gray-800"><%= exercise.name %></span>
          <!-- Later, you can add an edit/delete button here -->
        </li>
      <% end %>
    </ul>
  </div>
  
  <div class="mt-6">
    <%= link_to "&larr; Back to Workouts".html_safe, root_path, class: "text-blue-600 hover:underline" %>
  </div>
</div>